# ===========================================
# CONFIGURATION TENNIS PRONOSTICS BACKEND
# ===========================================

# Environment
NODE_ENV=development
PORT=3001

# PostgreSQL Database
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=tennis_claude_test
PG_USER=laurent
PG_PASSWORD=RATM94

# Microsoft Access Database (pour synchronisation)
ACCESS_CONNECTION_STRING=DRIVER={Microsoft Access Driver (*.mdb, *.accdb)};DBQ=C:\Program Files (x86)\OnCourt\\OnCourt.mdb;PWD=qKbE8lWacmYQsZ2;

# API Configuration
API_PREFIX=/api/v1
MAX_REQUESTS_PER_MINUTE=100
ENABLE_RATE_LIMITING=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
ENABLE_CONSOLE_LOGS=true

# Cron Jobs
ENABLE_AUTO_SYNC=true
SYNC_CRON_SCHEDULE=0 7,13,19 * * *
# Format: minute hour day month dayOfWeek
# Exemple ci-dessus: tous les jours à 7h et 19h

# Cache (Redis - optionnel pour plus tard)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
ENABLE_CACHE=false

# Security
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# External APIs (pour future intégration)
TENNIS_API_KEY=
ODDS_API_KEY=

# Email (pour notifications - optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@tennis-pronostics.com

# Monitoring (optionnel)
SENTRY_DSN=
ENABLE_MONITORING=false

# Development
ENABLE_SWAGGER=true
SWAGGER_HOST=localhost:3001
ENABLE_DEBUG_ROUTES=true